# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== 记忆图谱配置（二选一）=====
# 方案A：本地模式（推荐，完全免费，使用 Neo4j + Qdrant）
ZEP_USE_LOCAL=true
# Neo4j 图数据库（本地模式必须配置）
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
# Qdrant 向量数据库
QDRANT_URL=http://qdrant:6333

# 方案B：Zep Cloud 模式（需在 https://app.getzep.com/ 注册）
# 若使用方案B，请将 ZEP_USE_LOCAL 改为 false，并填入 ZEP_API_KEY
# ZEP_USE_LOCAL=false
# ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== 本地 Embedding 模型配置 =====
# 设置为 true 启用本地模型（推荐，速度更快且无需 API 费用）
EMBEDDING_USE_LOCAL=true
# 本地模型名称（支持 HuggingFace 模型名或本地路径）
# 推荐模型（按速度排序）:
# - paraphrase-multilingual-MiniLM-L12-v2 (384维，支持中英文，最快)
# - paraphrase-multilingual-MiniLM-L6-v2 (384维，更小更快)
# - distiluse-base-multilingual-cased-v2 (512维，效果好一些)
EMBEDDING_LOCAL_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# 模型缓存目录（可选，默认缓存到 ~/.cache/huggingface）
EMBEDDING_CACHE_DIR=/path/to/model/cache